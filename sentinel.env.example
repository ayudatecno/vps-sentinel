# vps-sentinel configuration — copy to /etc/vps-sentinel.env and chmod 0600.
# Only the two Telegram vars are required; everything else enables extra checks.

# ── Required: where alerts go ──────────────────────────────────────────────
# Create a bot with @BotFather, then get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN="123456789:AA..."
TELEGRAM_ADMIN_CHAT_IDS="11111111"        # CSV for multiple admins

# ── Node identity ──────────────────────────────────────────────────────────
NODE_ROLE="manager"                        # manager | worker
NODE_NAME="my-vps-1"                       # display name in alerts (default: hostname)
PEER_HOST=""                               # manager only: SSH-reachable peer to ping

# ── App watchdog (optional — enables `appwatch` mode) ─────────────────────
# Detects a hung-but-alive app and does ONE forced docker service restart.
APP_SERVICE=""                             # e.g. mystack_app (docker swarm service name)
APP_HEALTH_HOST=""                         # e.g. app.example.com (checked via local proxy AND publicly)
APP_HEALTH_PATH="/api/health"

# ── Backup freshness check (optional) ──────────────────────────────────────
# Your backup job must log a timestamped success line, e.g.:
#   [2026-05-06 00:02:19]  Backup complete
BACKUP_LOG=""                              # e.g. /var/log/backup.log
BACKUP_MAX_AGE_SEC="28800"                 # alert if older than this (8h)
BACKUP_OK_PATTERN=" Backup complete"

# ── Deploy grace (optional) ────────────────────────────────────────────────
# Your CI/CD should append a line to this file at deploy start + finish; while
# its mtime is fresh, replica-short + health failures are treated as expected.
DEPLOY_LOG=""                              # e.g. /var/log/deploy.log
DEPLOY_GRACE_SEC="300"

# ── Thresholds ─────────────────────────────────────────────────────────────
SENTINEL_DISK_WARN="85"
SENTINEL_DISK_CRIT="92"
SENTINEL_COOLDOWN="3600"                   # seconds between repeats of the same alert

# ── restore-drill.sh (optional) ────────────────────────────────────────────
RCLONE_REMOTE=""                           # e.g. b2:my-backups
PROD_DB_CONTAINER=""                       # name filter of the live pg container, e.g. mystack_db
PROD_DB_USER="postgres"
PROD_DB_NAME=""                            # database to verify
KEY_TABLES=""                              # e.g. "users orders invoices"
PG_IMAGE_FALLBACK="postgres:16"            # used if the prod image can't be auto-detected
